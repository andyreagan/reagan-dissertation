@article{Thurner2012,
	Abstract = {We study behavioral action sequences of players in a massive multiplayer online game. In their virtual life players use eight basic actions which allow them to interact with each other. These actions are communication, trade, establishing or breaking friendships and enmities, attack, and punishment. We measure the probabilities for these actions conditional on previous taken and received actions and find a dramatic increase of negative behavior immediately after receiving negative actions. Similarly, positive behavior is intensified by receiving positive actions. We observe a tendency towards antipersistence in communication sequences. Classifying actions as positive (good) and negative (bad) allows us to define binary 'world lines' of lives of individuals. Positive and negative actions are persistent and occur in clusters, indicated by large scaling exponents $\alpha$ \~{} 0.87 of the mean square displacement of the world lines. For all eight action types we find strong signs for high levels of repetitiveness, especially for negative actions. We partition behavioral sequences into segments of length n (behavioral 'words' and 'motifs') and study their statistical properties. We find two approximate power laws in the word ranking distribution, one with an exponent of $\kappa$ \~{} -1 for the ranks up to 100, and another with a lower exponent for higher ranks. The Shannon n-tuple redundancy yields large values and increases in terms of word length, further underscoring the non-trivial statistical properties of behavioral sequences. On the collective, societal level the timeseries of particular actions per day can be understood by a simple mean-reverting log-normal model.},
	Author = {Thurner, Stefan and Szell, Michael and Sinatra, Roberta},
	Date-Added = {2015-09-23 21:58:30 +0000},
	Date-Modified = {2015-09-23 21:58:31 +0000},
	Doi = {10.1371/journal.pone.0029796},
	File = {:Users/lewismitchell1984/Documents/Articles/Thurner, Szell, Sinatra - 2012 - Emergence of good conduct, scaling and zipf laws in human behavioral sequences in an online world.pdf:pdf},
	Issn = {1932-6203},
	Journal = {PloS one},
	Month = jan,
	Number = {1},
	Pages = {e29796},
	Pmid = {22253784},
	Title = {{Emergence of good conduct, scaling and zipf laws in human behavioral sequences in an online world.}},
	Url = {http://www.pubmedcentral.nih.gov/articlerender.fcgi?artid=3257232\&tool=pmcentrez\&rendertype=abstract},
	Volume = {7},
	Year = {2012},
	Bdsk-Url-1 = {http://www.pubmedcentral.nih.gov/articlerender.fcgi?artid=3257232%5C&tool=pmcentrez%5C&rendertype=abstract},
	Bdsk-Url-2 = {http://dx.doi.org/10.1371/journal.pone.0029796}}

