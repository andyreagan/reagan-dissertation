@article{Schmittner2002,
	Abstract = {In contrast to the relatively stable climate of the past 10,000 years, during glacial times the North Atlantic region experienced large-amplitude transitions between cold (stadial) and warm (interstadial) states. In this modeling study, we demonstrate that hydrological interactions between the Atlantic thermohaline circulation (THC) and adjacent continental ice sheets can trigger abrupt warming events and also limit the lifetime of the interstadial circulation mode. These interactions have the potential to destabilize the THC, which is already more sensitive for glacial conditions than for the present-day climate, thus providing an explanation for the increased variability of glacial climate.},
	Author = {Schmittner, Andreas and Yoshimori, Masakazu and Weaver, Andrew J},
	Date-Added = {2015-09-23 21:58:30 +0000},
	Date-Modified = {2015-09-23 21:58:31 +0000},
	Doi = {10.1126/science.1066174},
	File = {:Users/lewismitchell1984/Documents/Articles/Schmittner, Yoshimori, Weaver - 2002 - Instability of glacial climate in a model of the ocean- atmosphere-cryosphere system.pdf:pdf},
	Issn = {1095-9203},
	Journal = {Science},
	Month = feb,
	Number = {5559},
	Pages = {1489--93},
	Pmid = {11823604},
	Title = {{Instability of glacial climate in a model of the ocean- atmosphere-cryosphere system.}},
