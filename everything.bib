	Issn = {1089-7682},
	Journal = {Chaos (Woodbury, N.Y.)},
	Keywords = {Air Movements,Algorithms,Atmosphere,Climate,Computer Simulation,Models, Theoretical,Nonlinear Dynamics,Oscillometry,Oscillometry: methods,Weather},
