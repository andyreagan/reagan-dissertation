	Issn = {1364-503X},
	Journal = {Philosophical transactions. Series A, Mathematical, physical, and engineering sciences},
	Keywords = {climate oscillation,enso,from the annual to,irregular,nin,observational background,on time scales ranging,predictability,stochastic,system is the el,the decadal,the dominant form of,variability within the climate},
	Month = jul,
