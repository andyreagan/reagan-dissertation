@article{Kleeman2008,
	Abstract = {The El Ni\~{n}o/Southern Oscillation (ENSO) phenomenon is the dominant climatic fluctuation on interannual time scales. It is an irregular oscillation with a distinctive broadband spectrum. In this article, we discuss recent theories that seek to explain this irregularity. Particular attention is paid to explanations that involve the stochastic forcing of the slow ocean modes by fast atmospheric transients. We present a theoretical framework for analysing this picture of the irregularity and also discuss the results from a number of coupled ocean-atmosphere models. Finally, we briefly review the implications of the various explanations of ENSO irregularity to attempts to predict this economically significant phenomenon.},
	Author = {Kleeman, Richard},
	Date-Added = {2015-09-23 21:58:30 +0000},
	Date-Modified = {2015-11-04 23:05:56 +0000},
	Doi = {10.1098/rsta.2008.0048},
