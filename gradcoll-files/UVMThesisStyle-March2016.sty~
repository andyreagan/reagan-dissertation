% ===========================================
% Set up title environment
% ===========================================
\renewcommand\maketitle{%
    \thispagestyle{empty}
    \null%
    %\vskip 2em
    \begin{center}
        {\LARGE \textsc{ \@title } \par}
        \vskip 2em
        \doublespacing
        {
            \@thesistype\ Presented\\
	\vskip 2em
            by\\
            \@author\\
            to\\
            The Faculty of the Graduate College\\
            of\\
            The University of Vermont\\
            \vskip 2em
            \singlespacing
            In Partial Fulfillment of the Requirements\\
            for the Degree of \@degreetype\\
            Specializing in \@spectype\\
            \vskip 1em
            \@gradmonth, \number\year\par
        }
    \end{center} \par

	\vskip 2em
    	\begin{flushright}
	\singlespacing
	 Defense Date: \@defensedate\\
	 Dissertation Examination Committee:\\
	\vskip 1em
	\@advisor, Advisor\\
	\@readerone\\
	\@readertwo\\
	\@chair, Chairperson\\
	\@dean, Dean of Graduate College\\
	\end{flushright}

    \newpage
}

% ===============================================
% Commands to define the defense committee.
% ===============================================
\newcommand\advisor[1]{\gdef\@advisor{#1}}
\newcommand\readerone[1]{\gdef\@readerone{#1}}
\newcommand\readertwo[1]{\gdef\@readertwo{#1}}
\newcommand\chair[1]{\gdef\@chair{#1}}
\newcommand\dean[1]{\gdef\@dean{#1}}

\newcommand\defensedate[1]{\gdef\@defensedate{#1}}

\renewcommand{\headrulewidth}{0pt}

\newcommand\mainmatter{
  \pagestyle{fancy}
  \fancyhf{}
  \lhead{\leftmark}
  \cfoot{\thepage}
  \pagenumbering{arabic}
  \doublespacing
}

% ==========================================
% Set up various page environments
% ==========================================
% set up Dedication Environment
\newenvironment{dedication}{
\thispagestyle{plain}
\addcontentsline{toc}{section}{Dedication}
  \begin{center}
}{
  \end{center}
  \newpage
}

% set up acknowledgements Environment
\newenvironment{acknowledgements}{
    \section*{Acknowledgements}
    \addcontentsline{toc}{section}{Acknowledgements}
    \begin{doublespace}
    }{
    \end{doublespace}
    \newpage
}

% set up acknowledgements Environment
\newenvironment{citationspage}{
    %% \section*{Citations}
  %% \addcontentsline{toc}{section}{Acknowledgements}
    \begin{center}
    {\LARGE \sc Citations \par} 
    \singlespacing
  \end{center}
    }{
    \newpage
}

% set up abstract Environment
\renewenvironment{abstract}{
  \thispagestyle{empty}
  %% \section*{Abstract}
      \begin{center}
    {\LARGE \sc Abstract \par} 
    \singlespacing
      \end{center}
    \singlespacing
}{
    \pagenumbering{roman}
    \newpage
}

% set up list of figures Environment
\renewcommand\listoffigures{%
      \begin{center}
    {\LARGE \sc \listfigurename \par} 
    \singlespacing
      \end{center}
    %% \section*{
    %% \@mkboth{}{}}%
    \@starttoc{lof}%
    \addcontentsline{toc}{section}{\listfigurename}
    \newpage
}

% set up list of tables Environment
\renewcommand\listoftables{%
        \begin{center}
    {\LARGE \sc \listtablename \par} 
    \singlespacing
      \end{center}
    %% \section*{\listtablename
    %% \@mkboth{}{}}%
    \@starttoc{lot}%
    \addcontentsline{toc}{section}{\listtablename}
    \newpage
}

% publications Environment
\newcommand\citationheadingpublished{
    \vskip 3em
    Material from this \@citationthesistype\ has been published in the following form:\\
}

% ==========================================
% set up TOC title
% ==========================================
\renewcommand\contentsname{Table of Contents}
\renewcommand\tableofcontents{%
    %% \section*{\contentsname
  %% \@mkboth{}{}}%
      \begin{center}
    {\LARGE \sc \contentsname \par} 
    \singlespacing
      \end{center}  
    \@starttoc{toc}%
    \newpage
}

% ==========================================
% set up title styles
% ==========================================
% chapters
\titleformat{\chapter}[display]
{\bf\LARGE\sc}
{\chaptertitlename\ \thechapter}
{10pt}
{\bf\LARGE\sc}

% sections
\titleformat{\section}
{\bfseries\Large\sc}
{\thesection}
{1em}{}

% subsections
\titleformat{\subsection}
{\bfseries\large\sc}
{\thesubsection}
{1em}{}

