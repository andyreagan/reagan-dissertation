% ============================================
% Type of degree you are receiving
% ============================================
\def\thesis{\gdef\@thesistype{A Thesis}
    \gdef\@citationthesistype{Thesis}
\gdef\@acceptancethesistype{Thesis}}
\def\dissertation{\gdef\@thesistype{A Dissertation}
    \gdef\@citationthesistype{dissertation}
\gdef\@acceptancethesistype{Dissertation}}
\def\masterarts{\gdef\@degreetype{Master of Arts}}
\def\masterscience{\gdef\@degreetype{Master of Science}}
\def\doctorphilosophy{\gdef\@degreetype{Doctor of Philosophy}}

% ============================================
% add your Department here
% ============================================
\def\cs{\gdef\@spectype{Computer Science}}
\def\apma{\gdef\@spectype{Applied Mathematics}}
\def\matsci{\gdef\@spectype{Materials Science}}
\def\masci{\gdef\@spectype{Mathematical Sciences}}
\def\phys{\gdef\@spectype{Physics}}

% ============================================
% add your graduation month here
% ============================================
\def\octgrad{\gdef\@gradmonth{October}}
\def\marchgrad{\gdef\@gradmonth{March}}
\def\maygrad{\gdef\@gradmonth{May}}

% ===========================================
% Set up title environment
% ===========================================
\renewcommand\maketitle{ %%
    \thispagestyle{empty}
    %%
    %% \vskip 2em
    \begin{center}
      \singlespacing
        {\LARGE \textsc{ \@title } \par}
        \vskip 5em
        \doublespacing
        {
            \@thesistype\ Presented\\
	    \vskip 2em
            by\\
            %% \vskip 2em
            \@author\\
            to\\
            The Faculty of the Graduate College\\
            of\\
            The University of Vermont\\
            \vskip 5em
            \singlespacing
            In Partial Fulfillment of the Requirements\\
            for the Degree of \@degreetype\\
            Specializing in \@spectype\\
            \vskip 3em
            \@gradmonth, \number\year\par
        }
    \end{center} \par

    %% \vskip 3em
    \vfill
    	\begin{flushright}
	\singlespacing
	 Defense Date: \@defensedate\\
	 Dissertation Examination Committee:\\
	\vskip 1em
	\@advisor, Advisor\\
	\@readerone, Advisor\\
        \@chair, Chairperson\\
	\@readertwo\\
	\@dean, Dean of Graduate College\\
	\end{flushright}

    \newpage
}

% ===============================================
% Commands to define the defense committee.
% ===============================================
\newcommand\advisor[1]{\gdef\@advisor{#1}}
\newcommand\readerone[1]{\gdef\@readerone{#1}}
\newcommand\readertwo[1]{\gdef\@readertwo{#1}}
\newcommand\chair[1]{\gdef\@chair{#1}}
\newcommand\dean[1]{\gdef\@dean{#1}}

\newcommand\defensedate[1]{\gdef\@defensedate{#1}}

\renewcommand{\headrulewidth}{0pt}

\newcommand\mainmatter{
  \pagestyle{fancy}
  \fancyhf{}
  %% \lhead{\leftmark}
  \cfoot{\thepage}
  \pagenumbering{arabic}
  \doublespacing
}

% ==========================================
% Set up various page environments
% ==========================================
% set up Dedication Environment
\newenvironment{dedication}{
\thispagestyle{plain}
\addcontentsline{toc}{section}{Dedication}
  \begin{center}
}{
  \end{center}
  \newpage
}

% set up acknowledgements Environment
\newenvironment{acknowledgements}{
    \section*{Acknowledgements}
    \addcontentsline{toc}{section}{Acknowledgements}
    \begin{doublespace}
    }{
    \end{doublespace}
    \newpage
}

% set up acknowledgements Environment
\newenvironment{citationspage}{
    %% \section*{Citations}
  %% \addcontentsline{toc}{section}{Acknowledgements}
    %% \begin{center}
    {\noindent \Large \sc \hyperlink{toc}{Citations} \par}
    \singlespacing
  %% \end{center}
    }{
    \newpage
}

% set up abstract Environment
\renewenvironment{abstract}{
  \thispagestyle{empty}
  %% \section*{Abstract}
      %% \begin{center}
    {\noindent \Large \sc \hyperlink{toc}{Abstract} \par}
    \singlespacing
      %% \end{center}
    \singlespacing
}{
    \pagenumbering{roman}
    \newpage
}

% set up list of figures Environment
\renewcommand\listoffigures{%
      %% \begin{center} 
    {\noindent \Large \sc \listfigurename \par}
    \singlespacing
      %% \end{center}
    %% \section*{
    %% \@mkboth{}{}}%
    \@starttoc{lof}%
    \addcontentsline{toc}{section}{\listfigurename}
    \newpage
}

% set up list of tables Environment
\renewcommand\listoftables{%
        %% \begin{center}
    {\noindent \Large \sc \listtablename \par}
    \singlespacing
      %% \end{center}
    %% \section*{\listtablename
    %% \@mkboth{}{}}%
    \@starttoc{lot}%
    \addcontentsline{toc}{section}{\listtablename}
    \newpage
}

% publications Environment
\newcommand\citationheadingpublished{
    \vskip 3em
    Material from this \@citationthesistype\ has been published in the following form:\\
}

% ==========================================
% set up TOC title
% ==========================================
\renewcommand\contentsname{Table of Contents}
\renewcommand\tableofcontents{%
    %% \section*{\contentsname
  %% \@mkboth{}{}}%
  %% \begin{center}
  \phantomsection 
  \hypertarget{toc}{}
    {\noindent \Large \sc \hyperlink{toc}{\contentsname} \par}
    \singlespacing
    %% \end{center}
    {\hypersetup{linkcolor=black}
    \@starttoc{toc}%
    \newpage}
}

% ==========================================
% set up title styles
% ==========================================
% chapters

\titleformat{\chapter}[display]
{\bf\Large\sc}
{\chaptertitlename\ \hyperlink{toc}{\thechapter}}
{10pt}
{\bf\LARGE\sc}

% sections
\titleformat{\section}
{\bfseries\Large\sc}
{\hyperlink{toc}{\thesection}}
{1em}{}

% subsections
\titleformat{\subsection}
{\bfseries\large\sc}
{\hyperlink{toc}{\thesubsection}}
{1em}{}

% ==============================================================
% Set up ability to include Python code with syntax highlighting
% ==============================================================
\usepackage[T1]{fontenc}
\usepackage[scaled]{beramono}
\usepackage{listings}

\usepackage{upquote}
\usepackage{setspace}

\definecolor{parser}{rgb}{0.5,0.45,1.0}
\definecolor{slate}{rgb}{0.47,0.4,0.9}
\definecolor{forest}{rgb}{0,1,0}
\definecolor{brown}{rgb}{0.7,0.35,0.2}

\lstset{
    language=Python,
    basicstyle=\ttfamily\footnotesize\setstretch{1},
    showstringspaces=false,
    alsoletter={1234567890},
    morekeywords={models, lambda, forms},
    otherkeywords={\ , \}, \{},
    emphstyle=\color{black}\bfseries,
    upquote=true,
    morecomment=[s]{"""}{"""},
    %
    commentstyle=\color{blue}\slshape,
    emph={[2]def, return, for, print, if, in, elif, else},
    emphstyle=[2]\color{red},
    emph={[3]import, from, as},
    emphstyle=[3]\color{forest},
    emph={[4]help, type, int, True, False},
    emphstyle=[4]\color{brown},
    stringstyle=\color{slate},
    %
    tabsize=4,
    formfeed=\newpage,
    numbers=left,
    numberstyle=\tiny,
    stepnumber=1,
    numbersep=5pt,
    frame=lines
}

\newcommand{\code}[2]{
  \subsection*{#1}
  \lstinputlisting{#2}
}

\newenvironment{references}[1]{
  %% \addcontentsline{toc}{section}{References}
  %% \singlespacing
  \section{References}\begin{list}
	   {[\arabic{enumi}]}{\settowidth\labelwidth{#1}
	     \leftmargin\labelwidth
	     \advance\leftmargin\labelsep
	     \advance\leftmargin\bibindent
	     \itemindent -\bibindent
	     \listparindent \itemindent
	     \parsep \z@
	     \usecounter{enumi}}
	   \def\newblock{}
	   \sloppy
	   \sfcode`\.=1000\relax
}{
	\end{list}
}

\renewenvironment{thebibliography}[1]{
  \newpage
  %% \addcontentsline{toc}{chapter}{Bibliography}
  %% \singlespacing
  \chapter*{\refname\@mkboth
    {\uppercase{\refname}}{\uppercase{\refname}}}\begin{list}
	   {[\arabic{enumi}]}{\settowidth\labelwidth{#1}
	     \leftmargin\labelwidth
	     \advance\leftmargin\labelsep
	     \advance\leftmargin\bibindent
	     \itemindent -\bibindent
	     \listparindent \itemindent
	     \parsep \z@
	     \usecounter{enumi}}
	   \def\newblock{}
	   \sloppy
	   \sfcode`\.=1000\relax
}{
  \end{list}
  \newpage
}


